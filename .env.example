# 数据库连接（MongoDB）
DATABASE_URL="mongodb://localhost:27017/phase-server"

# 可选：不设置时自动生成并存储到数据库
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# CORS 来源（多个用逗号分隔，* 表示允许所有）
CORS_ORIGIN=*

# 服务端口
PORT=3000

# WebAuthn 配置（硬件密钥支持）
WEBAUTHN_RP_NAME=Phase
WEBAUTHN_RP_ID=localhost

# SIEM / 安全事件日志
SIEM_ENABLED=false
SIEM_METHOD=file
SIEM_FILE_PATH=/var/log/phase/security.log
# SIEM_SYSLOG_HOST=syslog.company.com
# SIEM_SYSLOG_PORT=514
# SIEM_HTTP_ENDPOINT=https://siem.company.com/api/events
# SIEM_HTTP_TOKEN=your_api_token
