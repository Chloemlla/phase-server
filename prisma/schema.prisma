generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// 键值配置表（jwt_secret / instance_salt / instance_token 等）
model Config {
  key   String @id @map("_id")
  value String

  @@map("config")
}

/// Пользователь表 (Multi-User)
model User {
  id        String   @id @default(uuid()) @map("_id")
  email     String   @unique
  authHash  String   @map("auth_hash")
  salt      String   // 特定于用户的盐，用于派生主密钥
  createdAt Int      @map("created_at")

  vault              Vault?
  sessions           Session[]
  membership         Membership?
  activationCodes    ActivationCode[]
  webauthnCredentials WebAuthnCredential[]

  @@map("users")
}

/// 加密保险库（每个用户独立）
model Vault {
  id            String @id @default(uuid()) @map("_id")
  userId        String @unique @map("user_id")
  encryptedData String @map("encrypted_data")
  version       Int    @default(1)
  updatedAt     Int    @map("updated_at")

  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vault")
}

/// 会话表（每个用户多个）
model Session {
  id         String  @id @default(uuid()) @map("_id")
  userId     String  @map("user_id")
  deviceName String  @default("") @map("device_name")
  ipAddress  String? @map("ip_address")
  createdAt  Int     @map("created_at")
  lastUsedAt Int     @map("last_used_at")
  expiresAt  Int     @map("expires_at")

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt], name: "idx_sessions_expires_at")
  @@map("sessions")
}

/// IP 限速表（原来是复合主键：key + windowStart，MongoDB 中转为 unique 索引）
model RateLimit {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  key         String @map("key")
  count       Int    @default(1)
  windowStart Int    @map("window_start")

  @@unique([key, windowStart])
  @@index([windowStart], name: "idx_rate_limits_window")
  @@map("rate_limits")
}

/// 激活码表
model ActivationCode {
  id             String  @id @default(uuid()) @map("_id")
  code           String  @unique                    // 激活码字符串
  membershipDays Int     @map("membership_days")    // 激活后赋予的会员天数
  note           String  @default("")               // 备注（可选）
  usedAt         Int?    @map("used_at")            // 使用时间（null 表示未使用）
  usedBy         String? @map("used_by")            // 使用该激活码的用户 ID
  createdAt      Int     @map("created_at")

  user           User?   @relation(fields: [usedBy], references: [id])

  @@map("activation_codes")
}

/// 会员状态表（每个用户独立）
model Membership {
  id        String @id @default(uuid()) @map("_id")
  userId    String @unique @map("user_id")
  expiresAt Int    @map("expires_at")               // 会员到期时间（Unix 秒）
  updatedAt Int    @map("updated_at")

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("membership")
}

/// WebAuthn 凭证表（硬件密钥）
model WebAuthnCredential {
  id           String  @id @default(uuid()) @map("_id")
  userId       String  @map("user_id")
  name         String                                 // 用户自定义名称（如 "YubiKey 5C"）
  credentialId String  @unique @map("credential_id")  // Base64 编码的凭证 ID
  publicKey    String  @map("public_key")             // Base64 编码的公钥
  counter      Int     @default(0)                    // 签名计数器
  aaguid       String? @map("aaguid")                 // 认证器 AAGUID
  transports   String? @map("transports")             // 传输方式（JSON 数组字符串）
  createdAt    Int     @map("created_at")
  lastUsedAt   Int?    @map("last_used_at")

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_webauthn_user_id")
  @@map("webauthn_credentials")
}

/// WebAuthn 挑战表（临时存储，5分钟过期）
model WebAuthnChallenge {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @unique @map("user_id")
  challenge String                                    // Base64 编码的挑战
  createdAt Int    @map("created_at")
  expiresAt Int    @map("expires_at")

  @@index([expiresAt], name: "idx_webauthn_challenges_expires")
  @@map("webauthn_challenges")
}
